# Pulse agent environment variables
# Copy to .env and fill in values: cp .env.example .env

# --- Required for full pipeline (summarization) ---
# Groq API key for llama-3.3-70b-versatile theme/quote generation
GROQ_API_KEY=

# --- Optional ---
# Override repository root (default: directory containing pyproject.toml)
# PULSE_ROOT=/path/to/m3_6

# Comma-separated recipients for deliver-email (overrides config/products/groww.yaml)
# PULSE_EMAIL_TO=you@example.com

# Email delivery mode: draft | send (hosted server supports draft only)
# PULSE_EMAIL_MODE=draft

# Skip MCP writes when true (or use `pulse dry-run`)
# PULSE_DRY_RUN=false

# Hugging Face / sentence-transformers model cache directory
# First run downloads BAAI/bge-small-en-v1.5 (~130MB)
# HF_HOME=~/.cache/huggingface

# Force embedding model device: cpu | cuda | mps
# Overrides config/pipeline.yaml embedding.device when set
# PULSE_EMBEDDING_DEVICE=cpu

# Google MCP server credentials live in config/mcp/*.env (not here).
# See config/mcp/docs-mcp.env.example and config/mcp/gmail-mcp.env.example
